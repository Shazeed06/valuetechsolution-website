# ===== Email delivery (sign up free at resend.com) =====
# Required for contact form to actually deliver leads via email.
# If unset, contact form falls back to webhook + WhatsApp deep-link.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Optional from-address. Default is Resend's sandbox sender.
# Once you verify a domain in Resend, switch to e.g. "Value Tech <hello@valuetechsolution.com>"
RESEND_FROM=Value Tech Solution <onboarding@resend.dev>

# ===== Webhook delivery (Slack / n8n / Zapier / Make / your CRM) =====
# Receives the same form payload as JSON. Optional.
CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxxxxxxx

# ===== Analytics (sign up free at posthog.com) =====
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===== Floating widgets =====
# E.164 format without leading +. Default: 918287245032
NEXT_PUBLIC_WHATSAPP_NUMBER=918287245032

# Cal.com booking link for the floating widget. Optional.
NEXT_PUBLIC_CAL_LINK=https://cal.com/your-username/intro
